# Example .env file for Unified-NSE-Analysis
# Copy to `.env` and fill real values. DO NOT commit `.env` (it's ignored).
#
# Replace placeholders with real values required by your environment.

# API keys
API_KEY=your_api_key_here
ALTERNATE_API_KEY=your_alternate_api_key_here

# Database / storage
DB_HOST=localhost
DB_PORT=5432
DB_NAME=unified_nse
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# Email / notifications
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASSWORD=your_smtp_password
EMAIL_FROM=reports@example.com

# Other settings
LOG_LEVEL=INFO
DATA_DIR=data

# End of file

