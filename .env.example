# Example .env file for Unified-NSE-Analysis
# Copy to `.env` and fill real values. DO NOT commit `.env` (it's ignored).
#
# Replace placeholders with real values required by your environment.

# API keys
API_KEY=your_api_key_here
ALTERNATE_API_KEY=your_alternate_api_key_here

# Web search (working-sector): SerpAPI for Yahoo search
SERPAPI_API_KEY=your_serpapi_key_here

# Database / storage
DB_HOST=localhost
DB_PORT=5432
DB_NAME=unified_nse
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# Email / notifications
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASSWORD=your_smtp_password
EMAIL_FROM=reports@example.com

# Other settings
LOG_LEVEL=INFO
DATA_DIR=data

# Ollama (local LLM) for dashboard market narrative
# Set OLLAMA_NARRATIVE_ENABLED=1 to use local Ollama to generate the narrative; otherwise rule-based narrative is used.
OLLAMA_NARRATIVE_ENABLED=0
OLLAMA_MODEL=granite4
OLLAMA_BASE_URL=http://localhost:11434

# End of file

